---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Sound" description="Acutonics vibrational sound therapy — a restorative experience grounded in Traditional Chinese Medicine, science, and psychology.">
  <Hero
    image="/images/hero-home.jpg"
    imageAlt="Sound healing tuning forks"
    title="Acutonics® Tuning Fork Therapy"
    compact
  />

  <!-- Intro quote -->
  <section class="py-20 px-6 bg-warm-50">
    <div class="max-w-3xl mx-auto text-center">
      <blockquote class="text-xl md:text-2xl text-warm-700 italic leading-relaxed">
        "When we consider that everything in and around us is vibrating at a specific frequency, we realize that sound is not just something we hear, but a force that can soothe, restore, and awaken us."
      </blockquote>
    </div>
  </section>

  <!-- Method description -->
  <section class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl text-warm-800 mb-8 text-center">The Acutonics® Sound Healing Method</h2>
      <div class="space-y-6 font-body text-warm-700 leading-relaxed">
        <p>
          Acutonics Sound Healing offers a restorative experience grounded in Traditional Chinese Medicine, science, and psychology. The body is viewed as a living garden where water, wood, fire, earth, and metal elements must flow in balance for wellness.
        </p>
        <p>
          Sessions use precision-calibrated tuning forks placed on acupuncture and chakra points to awaken energy systems. Sound waves travel through the body to release tension, restore flow, and invite deep relaxation.
        </p>
        <p>
          The method supports healing across physical conditions (muscular, neurological discomfort), emotional imbalances, psychological concerns, and spiritual needs — offering a path toward balance and wholeness.
        </p>
      </div>
    </div>
  </section>

  <!-- Prana / Frequency -->
  <section class="py-20 px-6 bg-sage-50">
    <div class="max-w-3xl mx-auto text-center">
      <blockquote class="text-lg md:text-xl text-sage-700 italic leading-relaxed mb-6">
        "Prana is the essence that flows in and around all beings — <em>the glittering current that animates life itself</em>. By attuning to the body and its subtle energies, we can nourish and cultivate this life force, known as Prana or Qi."
      </blockquote>
      <p class="font-body text-sage-600 text-lg">
        "Frequency is the rhythm at which this vital energy vibrates."
      </p>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl text-warm-800 mb-8 text-center">What to Expect</h2>
      <div class="space-y-6 font-body text-warm-700 leading-relaxed">
        <p>
          Sessions begin with clearing and intention-setting rituals creating sacred space. Calibrated tuning forks activate specific acupuncture points corresponding to meridians and chakras.
        </p>
        <p>
          Additional sound tools may include tingsha bells, Tibetan bowls, wooden flute, and kenari seed rattles to release stagnation and restore balance. Mantra, intention, and guided meditation deepen the experience.
        </p>
        <p>
          Participants may experience emotional release, memory surfacing, insights, physical tension dissolution, or profound calm and connection.
        </p>
      </div>

      <div class="mt-12 p-8 bg-warm-100 rounded-lg">
        <h3 class="text-xl text-warm-800 mb-4">Preparation</h3>
        <ul class="space-y-3 font-body text-warm-700">
          <li class="flex items-start gap-3">
            <span class="text-sage-500 mt-1">&#9679;</span>
            <span><strong>Location:</strong> Near Nyani Beach (details emailed after scheduling)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-sage-500 mt-1">&#9679;</span>
            <span><strong>Attire:</strong> Comfortable clothing; ideally shorts and sports top/bra for women, shirtless for men, to access acupuncture points precisely</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 bg-warm-100 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl text-warm-800 mb-6">Body, heart, and spirit care from adolescence to adulthood.</h2>
      <a
        href={`${base}connect`}
        class="inline-block px-8 py-3 bg-warm-700 text-white font-body text-sm tracking-wider uppercase rounded-md hover:bg-warm-800 transition-colors"
      >
        Book a Session
      </a>
    </div>
  </section>
</BaseLayout>
