        const subject = nlForm.subject.value;
        const htmlBody = nlForm.htmlBody.value;
        try {
          const res = await fetch('/api/newsletter-send', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ subject, htmlBody }) });
          const data = await res.json();
