      window.deleteNote = async function(id) {
        if (!confirm('Delete this note?')) return;
        await fetch('/api/notes', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
        loadNotes();
      };

      window.startEditNote = function(id) {
        const n = allNotes.find(x => x.id === id);
        if (!n) return;
        noteForm.text.value = n.text;
        noteForm.id.value = n.id;
        noteForm.text.focus();
      };

      // ═══════════════════ TIMER ═══════════════════
      // Meditation
      let medInterval = null, medSeconds = 600, medRunning = false;
      const medDisplay = document.getElementById('med-display');
      const medMinInput = document.getElementById('med-minutes');
      const medStartBtn = document.getElementById('med-start');

      function fmtTime(s) { return String(Math.floor(s / 60)).padStart(2, '0') + ':' + String(s % 60).padStart(2, '0'); }

      medMinInput.addEventListener('change', () => { if (!medRunning) { medSeconds = medMinInput.value * 60; medDisplay.textContent = fmtTime(medSeconds); } });

      medStartBtn.addEventListener('click', () => {
        if (medRunning) { clearInterval(medInterval); medRunning = false; medStartBtn.textContent = 'Start'; return; }
        medRunning = true; medStartBtn.textContent = 'Pause';
        medInterval = setInterval(() => {
          medSeconds--;
          medDisplay.textContent = fmtTime(medSeconds);
          if (medSeconds <= 0) { clearInterval(medInterval); medRunning = false; medStartBtn.textContent = 'Start'; alert('Meditation complete!'); }
        }, 1000);
      });

      document.getElementById('med-reset').addEventListener('click', () => {
        clearInterval(medInterval); medRunning = false; medStartBtn.textContent = 'Start';
        medSeconds = medMinInput.value * 60; medDisplay.textContent = fmtTime(medSeconds);
      });

      // Pomodoro
      let pomInterval = null, pomSeconds = 1500, pomRunning = false, pomWork = true;
      const pomDisplay = document.getElementById('pom-display');
      const pomPhase = document.getElementById('pom-phase');
      const pomStartBtn = document.getElementById('pom-start');

      pomStartBtn.addEventListener('click', () => {
        if (pomRunning) { clearInterval(pomInterval); pomRunning = false; pomStartBtn.textContent = 'Start'; return; }
        pomRunning = true; pomStartBtn.textContent = 'Pause';
        pomInterval = setInterval(() => {
          pomSeconds--;
          pomDisplay.textContent = fmtTime(pomSeconds);
          if (pomSeconds <= 0) {
            clearInterval(pomInterval); pomRunning = false; pomStartBtn.textContent = 'Start';
            pomWork = !pomWork;
            pomSeconds = pomWork ? 1500 : 300;
            pomPhase.textContent = pomWork ? 'WORK' : 'BREAK';
            pomDisplay.textContent = fmtTime(pomSeconds);
            alert(pomWork ? 'Break over — back to work!' : 'Work session done — take a break!');
          }
        }, 1000);
      });

      document.getElementById('pom-reset').addEventListener('click', () => {
        clearInterval(pomInterval); pomRunning = false; pomStartBtn.textContent = 'Start';
        pomWork = true; pomSeconds = 1500; pomDisplay.textContent = '25:00'; pomPhase.textContent = 'WORK';
      });

      // Stopwatch
      let swInterval = null, swMs = 0, swRunning = false, swLaps = [];
      const swDisplay = document.getElementById('sw-display');
      const swStartBtn = document.getElementById('sw-start');

      function fmtSw(ms) {
        const min = String(Math.floor(ms / 60000)).padStart(2, '0');
        const sec = String(Math.floor((ms % 60000) / 1000)).padStart(2, '0');
        const cs = String(Math.floor((ms % 1000) / 10)).padStart(2, '0');
        return `${min}:${sec}.${cs}`;
      }

      swStartBtn.addEventListener('click', () => {
        if (swRunning) { clearInterval(swInterval); swRunning = false; swStartBtn.textContent = 'Start'; return; }
        swRunning = true; swStartBtn.textContent = 'Pause';
        const start = Date.now() - swMs;
        swInterval = setInterval(() => { swMs = Date.now() - start; swDisplay.textContent = fmtSw(swMs); }, 10);
      });

      document.getElementById('sw-lap').addEventListener('click', () => {
        if (!swRunning) return;
        swLaps.push(fmtSw(swMs));
        document.getElementById('sw-laps').innerHTML = swLaps.map((l, i) => `<div>Lap ${i + 1}: ${l}</div>`).reverse().join('');
      });

      document.getElementById('sw-reset').addEventListener('click', () => {
        clearInterval(swInterval); swRunning = false; swStartBtn.textContent = 'Start';
        swMs = 0; swDisplay.textContent = '00:00.00'; swLaps = [];
        document.getElementById('sw-laps').innerHTML = '';
      });

      // ═══════════════════ HABITS ═══════════════════
      const habitForm = document.getElementById('habit-form');
      const habitFormCard = document.getElementById('habit-form-card');
      let allHabits = [], todayLogs = [];

      function clientToday() { return new Date().toISOString().slice(0, 10); }

      async function loadHabits() {
        try {
          const today = clientToday();
          const res = await fetch('/api/habits?today=' + today);
          const data = await res.json();
          allHabits = (data.habits || []).filter(h => h.status === 'active');
          todayLogs = data.todayLogs || [];
          renderHabits();
        } catch { document.getElementById('habits-list').innerHTML = '<div class="empty"><p>Failed to load.</p></div>'; }
      }

      function renderHabits() {
        const el = document.getElementById('habits-list');
        if (allHabits.length === 0) { el.innerHTML = '<div class="empty"><p>No habits yet. Add one above!</p></div>'; return; }
        const groups = {};
        allHabits.forEach(h => { const g = h.stackGroup || 'General'; if (!groups[g]) groups[g] = []; groups[g].push(h); });
        let html = '';
        for (const [group, habits] of Object.entries(groups)) {
          html += `<div class="habit-group-label">${esc(group)}</div>`;
          habits.forEach(h => {
            const done = todayLogs.some(l => l.habitId === h.id);
            html += `<div class="habit-item" onclick="toggleHabit('${h.id}', ${done})">
              <div class="habit-check ${done ? 'done' : ''}"></div>
              <div class="habit-name">${esc(h.name)}</div>
              <div style="text-align:right;">
                <div class="habit-streak">${h.currentStreak > 0 ? h.currentStreak + ' streak' : ''}</div>
                <div class="habit-freq">${h.frequency}</div>
              </div>
            </div>`;
          });
        }
        el.innerHTML = html;
      }

      document.getElementById('habit-add-btn').addEventListener('click', () => {
        habitFormCard.style.display = 'block';
        habitForm.reset();
        habitForm.name.focus();
      });

      document.getElementById('habit-cancel').addEventListener('click', () => {
        habitFormCard.style.display = 'none';
        habitForm.reset();
      });

      habitForm.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const fd = new FormData(habitForm);
        const body = Object.fromEntries(fd);
        body.action = 'save';
        if (!body.id) delete body.id;
        try {
          const res = await fetch('/api/habits', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
          if (res.ok) { habitFormCard.style.display = 'none'; habitForm.reset(); loadHabits(); }
          else showStatus('habits-status', 'Failed to save.', 'error');
        } catch { showStatus('habits-status', 'Network error.', 'error'); }
      });

      window.toggleHabit = async function(id, currentlyDone) {
        const action = currentlyDone ? 'uncomplete' : 'complete';
        const today = clientToday();
        try {
          await fetch('/api/habits', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action, id, today }) });
          loadHabits();
        } catch {}
      };

      // ═══════════════════ HELPERS ═══════════════════
      function esc(s) { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

      // Load initial tab
      loadFinances();
    </script>
  </body>
</html>
