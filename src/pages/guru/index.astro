      window.toggleNote = async function(id, completed) {
        const n = allNotes.find(x => x.id === id);
        if (!n) return;
        await fetch('/api/notes', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, text: n.text, completed }) });
        loadNotes();
