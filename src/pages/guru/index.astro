      blogForm.addEventListener('submit', async (ev) => {
        ev.preventDefault();
        const fd = new FormData(blogForm);
        const draft = Object.fromEntries(fd);
        try {
          const res = await fetch('/api/blog-drafts', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ draft }) });
          if (res.ok) { showStatus('blog-status', 'Draft saved!'); loadDrafts(); }
          else showStatus('blog-status', 'Failed to save draft.', 'error');
        } catch { showStatus('blog-status', 'Network error.', 'error'); }
      });

      document.getElementById('blog-publish-btn').addEventListener('click', async () => {
        const slug = blogForm.slug.value;
        if (!slug) { showStatus('blog-status', 'Enter a slug first.', 'error'); return; }
        if (!confirm('Publish this post?')) return;
        try {
          const fd = new FormData(blogForm);
          const body = Object.fromEntries(fd);
          const res = await fetch('/api/blog-publish', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
          if (res.ok) { showStatus('blog-status', 'Published!'); blogForm.reset(); loadDrafts(); loadPosts(); }
          else { const d = await res.json(); showStatus('blog-status', d.error || 'Publish failed.', 'error'); }
