        await fetch('/api/blog-drafts', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug }) });
        loadDrafts();
      };

      window.deletePost = async function(slug) {
        if (!confirm('Delete this published post from GitHub?')) return;
        await fetch('/api/blog-posts', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ slug }) });
        loadPosts();
