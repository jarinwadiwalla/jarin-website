      });

      document.getElementById('blog-clear').addEventListener('click', () => blogForm.reset());

      window.editDraft = async function(slug) {
        try {
          const res = await fetch('/api/blog-drafts');
          const data = await res.json();
          const d = (data.drafts || []).find(x => x.slug === slug);
          if (!d) return;
          blogForm.title.value = d.title;
          blogForm.slug.value = d.slug;
          blogForm.date.value = d.date || '';
          blogForm.image.value = d.image || '';
          blogForm.excerpt.value = d.excerpt || '';
          blogForm.body.value = d.body || '';
        } catch {}
      };

      window.deleteDraft = async function(slug) {
