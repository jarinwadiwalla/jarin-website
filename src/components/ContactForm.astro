---
{/* TODO: Replace YOUR_FORM_ID with your Formspree form ID from https://formspree.io */}
const formAction = "https://formspree.io/f/YOUR_FORM_ID";
---

<form action={formAction} method="POST" class="space-y-6">
  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <label for="first-name" class="block font-body text-sm text-warm-700 mb-2">First Name *</label>
      <input
        type="text"
        id="first-name"
        name="first-name"
        required
        class="w-full px-4 py-3 bg-white border border-warm-200 rounded-md font-body text-sm text-warm-800 placeholder:text-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-400 transition"
      />
    </div>
    <div>
      <label for="last-name" class="block font-body text-sm text-warm-700 mb-2">Last Name *</label>
      <input
        type="text"
        id="last-name"
        name="last-name"
        required
        class="w-full px-4 py-3 bg-white border border-warm-200 rounded-md font-body text-sm text-warm-800 placeholder:text-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-400 transition"
      />
    </div>
  </div>
  <div>
    <label for="email" class="block font-body text-sm text-warm-700 mb-2">Email Address *</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 bg-white border border-warm-200 rounded-md font-body text-sm text-warm-800 placeholder:text-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-400 transition"
    />
  </div>
  <div>
    <label for="phone" class="block font-body text-sm text-warm-700 mb-2">Phone</label>
    <input
      type="tel"
      id="phone"
      name="phone"
      class="w-full px-4 py-3 bg-white border border-warm-200 rounded-md font-body text-sm text-warm-800 placeholder:text-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-400 transition"
    />
  </div>
  <div>
    <label for="message" class="block font-body text-sm text-warm-700 mb-2">Message</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      class="w-full px-4 py-3 bg-white border border-warm-200 rounded-md font-body text-sm text-warm-800 placeholder:text-warm-400 focus:outline-none focus:ring-2 focus:ring-sage-400 transition resize-y"
    ></textarea>
  </div>
  <button
    type="submit"
    class="px-8 py-3 bg-warm-700 text-white font-body text-sm tracking-wider uppercase rounded-md hover:bg-warm-800 transition-colors"
  >
    Send
  </button>
</form>
