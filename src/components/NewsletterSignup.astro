---
interface Props {
  heading?: string;
  dark?: boolean;
}

const { heading = "Sign-up for news that's good for the soul.", dark = false } = Astro.props;
---

<div>
  <h3 class:list={['text-xl mb-4', dark ? 'text-white' : 'text-warm-800']}>
    {heading}
  </h3>
  {/* TODO: Connect to Mailchimp, ConvertKit, or preferred email provider */}
  <form class="flex gap-2" action="#" method="POST">
    <input
      type="email"
      name="email"
      placeholder="Email Address"
      required
      class:list={[
        'flex-1 px-4 py-3 rounded-md font-body text-sm focus:outline-none focus:ring-2 focus:ring-sage-400 transition',
        dark
          ? 'bg-white/10 border border-white/20 text-white placeholder:text-white/50'
          : 'bg-white border border-warm-200 text-warm-800 placeholder:text-warm-400',
      ]}
    />
    <button
      type="submit"
      class="px-6 py-3 bg-warm-700 text-white font-body text-sm tracking-wider uppercase rounded-md hover:bg-warm-800 transition-colors"
    >
      Sign Up
    </button>
  </form>
</div>
