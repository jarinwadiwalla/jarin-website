---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}sound`, label: 'Sound' },
  { href: `${base}community`, label: 'Community' },
  { href: `${base}about`, label: 'About' },
  { href: `${base}connect`, label: 'Connect' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-warm-50/90 backdrop-blur-sm border-b border-warm-200/50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={base} class="flex items-center gap-3">
      <img src={`${base}images/logo.png`} alt="Jarin Wadiwalla" class="h-10 w-auto" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'font-body text-sm tracking-widest uppercase transition-colors duration-200',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-warm-800 border-b border-warm-400'
                : 'text-warm-600 hover:text-warm-800',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://www.instagram.com/jarinwadiwalla"
          target="_blank"
          rel="noopener noreferrer"
          class="text-warm-600 hover:text-warm-800 transition-colors"
          aria-label="Instagram"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </li>
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-warm-700 p-2"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-warm-50/95 backdrop-blur-sm border-b border-warm-200/50">
    <ul class="px-6 py-4 space-y-4">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block font-body text-sm tracking-widest uppercase',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-warm-800'
                : 'text-warm-600',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
